# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# Database — set to Neon or any PostgreSQL instance
DB_URL=jdbc:postgresql://your-host.neon.tech/neondb?sslmode=require&sslrootcert=system
DB_USERNAME=neondb_owner
DB_PASSWORD=your-password-here

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-256-bit-base64-secret

# Jasypt encryption password (for AI API key storage)
JASYPT_PASSWORD=replace-with-strong-password
